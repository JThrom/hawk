{
  "name": "hawk",
  "version": "0.1.0",
  "description": "A terminal user interface for discovering, launching, and installing other TUIs",
  "type": "module",
  "bin": {
    "hawk": "./src/index.ts"
  },
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "gen-registry": "bun run scripts/gen-registry.ts"
  },
  "keywords": [
    "tui",
    "launcher",
    "terminal",
    "tmux",
    "zellij"
  ],
  "license": "GPL-2.0-only",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.4.5",
    "yaml": "^2.9.0"
  }
}
